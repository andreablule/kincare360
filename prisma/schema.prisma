generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password           String
  name               String
  role               String    @default("CLIENT") // CLIENT | MANAGER | FAMILY | ADMIN
  stripeCustomerId   String?
  subscriptionStatus String?
  plan               String?   // ESSENTIAL | PLUS | COMPLETE | ESSENTIAL_FAMILY | PLUS_FAMILY | COMPLETE_FAMILY
  pendingPlan        String?
  pendingPlanDate    DateTime?
  inviteToken        String?
  inviteExpiry       DateTime?
  patientId          String?   // For FAMILY users — direct link to their patient
  createdAt          DateTime  @default(now())
  patients           Patient[]
  familyProfile      FamilyMember? @relation("UserFamilyProfile")
}

model Patient {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id])
  firstName         String
  lastName          String
  dob               String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zip               String?
  preferredCallTime    String?
  medicationReminderTime String?
  checkInDays          String?   // comma-separated: "Mon,Tue,Wed,Thu,Fri"
  gender               String?
  preferredLanguage    String?   @default("English")
  insuranceCompany     String?
  insuranceMemberId    String?
  insuranceGroupNumber String?
  insurancePolicyHolder String?
  referralCode         String?
  referral             Referral? @relation("ReferredBy", fields: [referralCode], references: [code])
  createdAt            DateTime  @default(now())
  doctors           Doctor[]
  pharmacies        Pharmacy[]
  medications       Medication[]
  conditions        Condition[]
  familyMembers     FamilyMember[]
  serviceRequests   ServiceRequest[]
  callLogs          CallLog[]
  reminders         Reminder[]
}

model Doctor {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  name      String
  specialty String?
  phone     String?
  address   String?
  notes     String?
}

model Pharmacy {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  name      String
  phone     String?
  address   String?
}

model Medication {
  id                String   @id @default(cuid())
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id])
  name              String
  dosage            String?
  frequency         String?
  instructions      String?
  reminderTime      String?  // HH:MM 24-hour format, e.g. "08:00"
  lastRefillDate    DateTime?
  refillIntervalDays Int?
  pharmacyName      String?
  pharmacyPhone     String?
}

model Condition {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])
  name      String
  notes     String?
}

model FamilyMember {
  id              String  @id @default(cuid())
  patientId       String
  patient         Patient @relation(fields: [patientId], references: [id])
  name            String
  gender          String?
  relationship    String?
  phone           String?
  email           String?
  notifyUpdates   Boolean @default(true)
  userId          String?  @unique
  user            User?    @relation("UserFamilyProfile", fields: [userId], references: [id])
  alertMode       String  @default("email")    // email | text | both | none
  summaryTime     String  @default("18:00")    // HH:MM 24h — when daily digest is sent
  alertsEnabled   Boolean @default(true)       // opt in/out of non-emergency alerts
  lastDigestSent  DateTime?                     // prevent duplicate digests
}

model ServiceRequest {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  type        String   // APPOINTMENT | FOLLOWUP | MEDICATION_CHANGE | OTHER
  description String?
  status      String   @default("PENDING") // PENDING | IN_PROGRESS | DONE
  createdAt   DateTime @default(now())
}

model CallLog {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  callDate        DateTime
  summary         String?
  mood            String?
  medicationsTaken Boolean @default(false)
  concerns        String?
  urgent          Boolean  @default(false)
  transcript         String?
  callType           String?
  servicesRequested  String?  // JSON: [{service, providerName, providerPhone, outcome}]
  createdAt          DateTime @default(now())
}

model Referral {
  id              String    @id @default(cuid())
  code            String    @unique
  type            String    // client | family | partner
  referrerName    String
  referrerEmail   String?
  referrerPhone   String?
  practiceName    String?
  userId          String?
  familyMemberId  String?
  stripeAccountId String?
  payoutMethod    String?   // credit | stripe_connect
  earnings        Float     @default(0)
  referralCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  conversions     ReferralConversion[]
  patients        Patient[] @relation("ReferredBy")
}

model Reminder {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  message     String
  scheduledAt DateTime
  status      String   @default("pending") // pending | sent | failed
  createdAt   DateTime @default(now())
}

model ReferralConversion {
  id            String    @id @default(cuid())
  referralId    String
  referral      Referral  @relation(fields: [referralId], references: [id])
  newCustomerId String
  status        String    @default("pending")
  amount        Float     @default(50)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
}

model Prospect {
  id         String   @id @default(cuid())
  phone      String
  name       String?
  callCount  Int      @default(1)
  lastCallAt DateTime
  summary    String?
  mood       String?
  concerns   String?
  status     String   @default("NEW") // NEW | CONTACTED | CONVERTED | LOST
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
